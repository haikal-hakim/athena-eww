(defwidget widget_dashboard_music []
  (box :class "music-card"
       :orientation "horizontal"
       :space-evenly false
       :spacing 20
       :width 320
       :hexpand false

       (box :class "music-cover"
            :style "background-image: url('${EWW_CONFIG_DIR}/assets/music.png');"
            :width 100)

       (box :class "music-info"
            :orientation "vertical"
            :space-evenly false
            :spacing 8
            :valign "center"
            :hexpand true

            (label :class "music-title"
                   :text {music_data.title == "No Media" || music_data.title == "" ? "Nothing Playing" : music_data.title}
                   :limit-width 20
                   :halign "center")

            (label :class "music-artist"
                   :text {music_data.artist == "No Artist" || music_data.artist == "" ? "No Artist" : music_data.artist}
                   :limit-width 20
                   :halign "center")

            (box :class "music-controls"
                 :orientation "horizontal"
                 :space-evenly true

                 (eventbox :cursor "pointer"
                           (button :onclick "playerctl --player=spotify previous"
                                   :style "background: none; box-shadow: none;"
                                   (label :text "󰒮")))

                 (eventbox :cursor "pointer"
                           (button :onclick "playerctl --player=spotify play-pause"
                                   :style "background: none; box-shadow: none;"
                                   (label :text {music_data.status == "Playing" ? "󰏤" : "󰐊"})))

                 (eventbox :cursor "pointer"
                           (button :onclick "playerctl --player=spotify next"
                                   :style "background: none; box-shadow: none;"
                                   (label :text "󰒭")))
            )
       )
  )
)
