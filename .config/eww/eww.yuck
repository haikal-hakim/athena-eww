;; @author Muhammad Haikal Hakim
;; @repository https://github.com/haikal-hakim/athena-eww

(defvar open_dashboard false)

;; --- ROOT ---
(include "./bar/bar.yuck")
(include "./corner/corner.yuck")
(include "./dashboard/dashboard.yuck")
(include "./panel/panel.yuck")


;; --- BAR ---
(defwindow window_bar
  :monitor 0
  :geometry (geometry :x "0%"
                      :y "0.5%"
                      :width "80%"
                      :height "0px"
                      :anchor "top center")
  :stacking "fg"
  :windowtype "dock"
  :exclusive true
  :wm-ignore false
  :namespace "eww-bar"
  (widget_bar))

;; --- DASHBOARD ---
(defwindow window_dashboard
  :monitor 0
  :geometry (geometry :x "0%"
                      :y "13%"
                      :width 0
                      :height 0
                      :anchor "top center")
  :stacking "overlay"
  :windowtype "dialog"
  :wm-ignore true
  :namespace "eww-dashboard"
  (dashboard_layout))

;; --- PANEL ---
(defwindow window_panel
  :monitor 0
  :geometry (geometry :x "20px"
                      :y "20px"
                      :width "420px"
                      :height "380px"
                      :anchor "top right")
  :stacking "fg"
  :namespace "eww-panel"
  (widget_panel))

